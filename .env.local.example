# Step 1.4 bench harness locals
IPHONE_UDID=00000000-0000000000000000
BUNDLE_ID=com.phejet.dubaicmd
# Optional: override the Mac LAN host the iPhone reaches. If unset,
# scripts/bench.sh auto-detects via `ipconfig getifaddr en0` (en1/en2/en3 fallback).
# MAC_HOSTNAME=YourMacName.local
# Optional pinned baseline root for scripts/bench.sh compare output
# PERF_BASELINE_DIR=perf-results/baselines/<buildId>
